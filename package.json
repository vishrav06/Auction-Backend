{
  "name": "auction-backend",
  "version": "1.0.0",
  "description": "Backend for the auction website",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon --exec \"ts-node -r dotenv/config\" src/index.ts",
    "build": "tsc",
    "start": "node -r dotenv/config dist/index.js",
    "migrate:up": "node-pg-migrate up --migrations-dir src/migrations --database-url-var DATABASE_URL",
    "migrate:down": "node-pg-migrate down --migrations-dir src/migrations --database-url-var DATABASE_URL",
    "migrate:create": "node-pg-migrate create --migrations-dir src/migrations"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
